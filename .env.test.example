# Copy to .env.test and fill in values from your isolated Neon test branch.
#
# IMPORTANT: never point DATABASE_URL at a production or shared database.
# The test suite runs destructive operations (deleteMany, truncate) before
# each test suite. Use a dedicated Neon branch or a local Postgres instance.
#
# If the database name does not contain a recognisable test marker
# (test, shadow, ci, dev, local, staging), you MUST set TEST_DB_CONFIRMED=1
# to confirm the endpoint is isolated.

# Non-pooled Neon connection (avoid PgBouncer transaction-mode limitations)
DATABASE_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb_test?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb_test?sslmode=require&channel_binding=require"

# Set to 1 when using an isolated Neon branch whose DB name does not contain
# a recognised test marker (e.g. Neon's default "neondb" branch name).
# TEST_DB_CONFIRMED=1
