# Copy to .env.local and fill in real values from Neon dashboard
# DATABASE_URL: pooled connection string (for app queries)
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# DIRECT_URL: non-pooled connection string (for prisma migrate)
# Same as DATABASE_URL but without "-pooler" in the hostname
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
